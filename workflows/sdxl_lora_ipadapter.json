      "strength_clip": 0.85
    }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "prompt",
      "clip": [
        "12",
        1
      ]
    }
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "negative",
      "clip": [
        "12",
        1
      ]
    }
  },
  "5": {
